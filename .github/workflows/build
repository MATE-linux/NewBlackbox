name: Build NewBlackbox APK

on:
  push:
    branches: [ main, master ]  # Запуск при пуше в main/master
  pull_request:
    branches: [ main, master ]  # Запуск при создании PR
  workflow_dispatch:            # Возможность запустить вручную

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
    - name: Checkout code
      uses: actions/checkout@v4

    - name: Set up JDK 17
      uses: actions/setup-java@v4
      with:
        distribution: 'temurin'
        java-version: '17'

    - name: Setup Gradle
      uses: gradle/actions/setup-gradle@v3

    - name: Grant execute permission for gradlew
      run: chmod +x gradlew

    - name: Build Debug APK
      run: ./gradlew assembleDebug

    - name: Upload Debug APK
      uses: actions/upload-artifact@v4
      with:
        name: NewBlackbox-debug
        path: app/build/outputs/apk/debug/*.apk

    - name: Build Release APK (unsigned)
      run: ./gradlew assembleRelease

    - name: Upload Release APK
      uses: actions/upload-artifact@v4
      with:
        name: NewBlackbox-release-unsigned
        path: app/build/outputs/apk/release/*.apk

    - name: Upload AARs
      uses: actions/upload-artifact@v4
      with:
        name: NewBlackbox-aars
        path: Bcore/build/outputs/aar/*.aar
